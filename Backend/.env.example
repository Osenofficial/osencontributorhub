# ==========================================
# HACKCOMET - Environment Variables Template
# ==========================================
# Copy this file to .env.local and fill in your values

# Application Settings
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=hackComet

# MongoDB Database Connection
# For local development: mongodb://localhost:27017/osencontributorhub
# For MongoDB Atlas: copy the URI from the Atlas "Drivers" tab
# Example:
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/osencontributorhub?retryWrites=true&w=majority&appName=osencontributorhub
MONGODB_URI=
MONGODB_DB_NAME=osencontributorhub

# Authentication
# Generate a secure random string for production
# Example: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Session
SESSION_SECRET=your-session-secret-key-change-in-production

# API Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=15

# Node Environment
# Options: development, production, test
NODE_ENV=development

# Email Configuration (Optional)
# Option A - Resend (recommended for fast delivery, ~seconds):
# Get API key at https://resend.com/api-keys . Verify domain at https://resend.com/domains
# RESEND_API_KEY=re_xxxxxxxxxxxx
# RESEND_FROM="hackComet <onboarding@resend.dev>"
# Option B - SMTP (e.g. Gmail; can be slow or delayed):
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_REQUIRE_TLS=true
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM="hackComet <your-email@gmail.com>"
EMAIL_REPLY_TO=hackcomettesting@gmail.com
# Used in email subject/body (optional; defaults to "OSEN Contributor Hub")
EMAIL_APP_NAME=OSEN Contributor Hub
# When true, Nodemailer sends mail (see src/lib/mail.ts). SMTP must be set above.
ENABLE_EMAIL_NOTIFICATIONS=false
# Set to true to skip email OTP verification (signup = instant login)
SKIP_EMAIL_VERIFICATION=false

# Optional: AWS S3 (for file uploads)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=

# Optional: Analytics
# GOOGLE_ANALYTICS_ID=
# MIXPANEL_TOKEN=
